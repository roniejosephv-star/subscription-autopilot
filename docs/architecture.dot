digraph SubscriptionAutopilot {
  graph [
    fontname="Helvetica"
    label=<<B>Subscription Autopilot — Architecture</B><BR/><FONT POINT-SIZE="11">Ignyte × Circle × Arc · Track 4 (Agentic Economy) · Arc Testnet (chain 5042002, gas = USDC)</FONT>>
    labelloc="t"
    fontsize=18
    pad="0.4"
    nodesep=0.55
    ranksep=0.75
    bgcolor="white"
    compound=true
  ]
  node [fontname="Helvetica" shape=box style="rounded,filled" fontsize=11 margin="0.18,0.12"]
  edge [fontname="Helvetica" fontsize=9.5 color="#555555"]

  subgraph cluster_untrusted {
    label=<<B>UNTRUSTED ZONE</B> — LLM, injectable, zero key material>
    fontsize=11
    fontcolor="#b3261e"
    color="#b3261e"
    style="dashed"
    agent [
      fillcolor="#fdecea" color="#b3261e"
      label=<<B>AUTOPILOT AGENT</B><BR/><FONT POINT-SIZE="9.5">Claude tool-use planner / deterministic loop<BR/>subscribe · meter usage · renewal cron<BR/>re-shop across sellers · re-plan on denial<BR/><B>no keys · no Circle SDK · no chain RPC</B></FONT>>
    ]
  }

  subgraph cluster_trusted {
    label=<<B>CUSTODY BOUNDARY</B> — the only process that can move money>
    fontsize=11
    fontcolor="#0b6e4f"
    color="#0b6e4f"
    style="dashed"
    signer [
      fillcolor="#e6f4ef" color="#0b6e4f"
      label=<<B>SPENDGUARD</B>  (policy-gated signer, :5000)<BR/><FONT POINT-SIZE="9.5">policy chain: allowlist → perTx → monthly →<BR/>perService → velocity → approval threshold<BR/>allow → GatewayClient.pay() · hold → human queue · deny → structured code<BR/>x402 <B>onBeforePaymentCreation</B> hook = enforcement point<BR/>keys: <B>Circle Wallets</B> DCW EOA (or local fallback)</FONT>>
    ]
  }

  dashboard [
    fillcolor="#eef2fb" color="#3b5bdb"
    label=<<B>OWNER DASHBOARD</B>  (Next.js, Vercel)<BR/><FONT POINT-SIZE="9.5">burn-down · live feed · approve / deny · savings · Arc receipts</FONT>>
  ]

  sellers [
    fillcolor="#fff8e6" color="#b8860b"
    label=<<B>SELLERS ×3</B>  (x402, :4001–4003)<BR/><FONT POINT-SIZE="9.5"><B>Circle Nanopayments</B> middleware<BR/>price re-resolved per request — volume/loyalty tiers<BR/>= the agent&#39;s negotiation surface</FONT>>
  ]

  gateway [
    fillcolor="#e6f0fa" color="#1971c2"
    label=<<B>CIRCLE GATEWAY</B>  (testnet)<BR/><FONT POINT-SIZE="9.5">batched, gas-free <B>USDC</B> settlement<BR/>unified balance · transfer UUID receipts</FONT>>
  ]

  arc [
    fillcolor="#f3eefb" color="#6741d9"
    label=<<B>ARC TESTNET — SpendAnchor.sol</B><BR/><FONT POINT-SIZE="9.5">0xfe18…e435 · anchorPolicy(hash) · commitEpoch(n, root, spent)<BR/>tamper-evident audit of every policy version + spend epoch</FONT>>
  ]

  // flows
  agent -> signer [label=<POST /pay {url, serviceId, reason}<BR/>← 200 receipt | 402 {code, reason} | 202 hold> penwidth=1.6 color="#b3261e"]
  agent -> sellers [label="GET /quote (free probe)" style=dashed]
  signer -> sellers [label=<x402 paid request<BR/>EIP-3009 auth, policy-approved> penwidth=1.6 color="#0b6e4f"]
  sellers -> gateway [label="verify + settle (batched)"]
  signer -> arc [label="anchorPolicy · commitEpoch"]
  dashboard -> signer [label=</ledger · /approvals · /summary (poll 2s)<BR/>human approve / deny> dir=both color="#3b5bdb"]
}
