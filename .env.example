# ── Circle (console.circle.com — account under roniejosephv@gmail.com) ─────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Agent wallet — filled by `npm run generate-wallet` (DCW EOA on ARC-TESTNET)
AGENT_WALLET_ID=
AGENT_WALLET_ADDRESS=

# Signing mode: "circle" (LIVE default — keyless via Circle DCW; signs payments AND on-chain anchors)
#             | "local"  (offline-dev fallback — uses the raw key below for payments; does NOT anchor)
SIGNER_MODE=circle

# LOCAL-MODE ONLY: raw EOA key used for payment signing when SIGNER_MODE=local.
# Unused in circle mode (payments and anchoring both go through Circle contract-execution).
# Generate: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
# Fund its address with Arc Testnet USDC at https://faucet.circle.com
SIGNER_FALLBACK_PRIVATE_KEY=

# ── Anthropic (agent reasoning; optional — agent has a deterministic --no-llm mode) ─
ANTHROPIC_API_KEY=

# ── Sellers (receive side; any EVM addresses you control) ──────────────────────
SELLER_ADDRESS_A=
SELLER_ADDRESS_B=
SELLER_ADDRESS_C=

# ── Services ────────────────────────────────────────────────────────────────────
# NOTE: never use port 5000 — macOS AirPlay Receiver owns it
SIGNER_PORT=5001
SIGNER_URL=http://localhost:5001
SELLER_PORT_A=4001
SELLER_PORT_B=4002
SELLER_PORT_C=4003
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ── Policy defaults (USDC, decimal strings) ─────────────────────────────────────
POLICY_MONTHLY_BUDGET=10
POLICY_PER_SERVICE_CAP=3
POLICY_PER_TX_MAX=0.05
POLICY_APPROVAL_THRESHOLD=0.02
POLICY_DAILY_TX_MAX=500
APPROVAL_WAIT_MS=60000

# ── Arc anchoring (optional until contract deployed Day 4) ──────────────────────
ANCHOR_CONTRACT_ADDRESS=

# ── Dashboard ───────────────────────────────────────────────────────────────────
# The dashboard proxies /api/signer/* to SpendGuard server-side (next.config.mjs).
# Set this to the signer's internal URL in deployed environments:
SIGNER_INTERNAL_URL=http://localhost:5001
# Optional override: make the browser hit the signer directly (bypasses the proxy)
# NEXT_PUBLIC_SIGNER_URL=http://localhost:5001
EPOCH_COMMIT_INTERVAL_MS=600000  # auto-anchor spend epochs on Arc every 10 min (0 = manual only)

# ── Autonomous cross-chain treasury (CCTP) — opt-in ─────────────────────────────
# Agent refills its Arc Gateway balance from a source chain when it runs low.
TREASURY_AUTOPILOT=          # set to 1 to enable the self-top-up loop
TREASURY_MIN_USDC=2          # top up when gateway available < this
TREASURY_TOPUP_USDC=5        # amount to pull per top-up
TREASURY_COOLDOWN_MS=600000  # min gap between top-ups
# CCTP execution (set from https://developers.circle.com/cctp + a funded source-chain DCW wallet):
CCTP_SOURCE_WALLET_ID=       # DCW wallet on the source chain (holds spare USDC)
CCTP_SOURCE_USDC=            # USDC token address on the source chain
CCTP_SOURCE_TOKEN_MESSENGER= # CCTP TokenMessenger on the source chain
CCTP_ARC_DOMAIN=             # Arc's CCTP destination domain id
CCTP_ARC_MESSAGE_TRANSMITTER=# CCTP MessageTransmitter on Arc
CCTP_IRIS_URL=https://iris-api-sandbox.circle.com

# ── USYC tokenized-yield leg (enterprise-gated; flip on when access granted) ─────
USYC_ENABLED=                # set to 1 once USYC access is granted
USYC_CONTRACT=               # USYC token/vault contract on Arc (from gated docs)
USYC_USDC=                   # USDC address used to subscribe (defaults to CCTP_SOURCE_USDC)
USYC_INVEST_FN=deposit(uint256)   # fill exact ABI signature from USYC docs
USYC_REDEEM_FN=redeem(uint256)

# ── StableFX cross-currency settlement (enterprise-gated; flip on when granted) ──
STABLEFX_ENABLED=            # set to 1 once StableFX access is granted
STABLEFX_BASE_URL=           # StableFX API base (from gated docs)
STABLEFX_API_KEY=            # defaults to CIRCLE_API_KEY if unset
STABLEFX_QUOTE_PATH=/v1/fx/quotes
STABLEFX_SETTLE_PATH=/v1/fx/settlements
