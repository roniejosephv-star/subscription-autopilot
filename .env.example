# ── Circle (console.circle.com — account under roniejosephv@gmail.com) ─────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=

# Agent wallet — filled by `npm run generate-wallet` (DCW EOA on ARC-TESTNET)
AGENT_WALLET_ID=
AGENT_WALLET_ADDRESS=

# Fallback / Day-0 path: local EOA private key (generate: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))")
# Fund its address with Arc Testnet USDC at https://faucet.circle.com
SIGNER_FALLBACK_PRIVATE_KEY=

# Signing mode: "local" (Day 0, uses fallback key) | "circle" (F8: DCW signTypedData — verify Day 1)
SIGNER_MODE=local

# ── Anthropic (agent reasoning; optional — agent has a deterministic --no-llm mode) ─
ANTHROPIC_API_KEY=

# ── Sellers (receive side; any EVM addresses you control) ──────────────────────
SELLER_ADDRESS_A=
SELLER_ADDRESS_B=
SELLER_ADDRESS_C=

# ── Services ────────────────────────────────────────────────────────────────────
# NOTE: never use port 5000 — macOS AirPlay Receiver owns it
SIGNER_PORT=5001
SIGNER_URL=http://localhost:5001
SELLER_PORT_A=4001
SELLER_PORT_B=4002
SELLER_PORT_C=4003
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ── Policy defaults (USDC, decimal strings) ─────────────────────────────────────
POLICY_MONTHLY_BUDGET=10
POLICY_PER_SERVICE_CAP=3
POLICY_PER_TX_MAX=0.05
POLICY_APPROVAL_THRESHOLD=0.02
POLICY_DAILY_TX_MAX=200
APPROVAL_WAIT_MS=60000

# ── Arc anchoring (optional until contract deployed Day 4) ──────────────────────
ANCHOR_CONTRACT_ADDRESS=

# ── Dashboard ───────────────────────────────────────────────────────────────────
# The dashboard proxies /api/signer/* to SpendGuard server-side (next.config.mjs).
# Set this to the signer's internal URL in deployed environments:
SIGNER_INTERNAL_URL=http://localhost:5001
# Optional override: make the browser hit the signer directly (bypasses the proxy)
# NEXT_PUBLIC_SIGNER_URL=http://localhost:5001
