# ==============================================================================
# SUBSCRIPTION AUTOPILOT - DUMMY .ENV FOR LLM RESEARCH
# ==============================================================================
# Copy this file to .env and fill in actual values
# All values below are placeholders for understanding structure
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# CIRCLE PROVIDER (Crypto payments - get from console.circle.com)
# ─────────────────────────────────────────────────────────────────────────────
CIRCLE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CIRCLE_ENTITY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# SIGNER WALLET (Day 0: Autonomous local key)
# Generate key: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
# Fund address at https://faucet.circle.com on Arc Testnet
# ─────────────────────────────────────────────────────────────────────────────
SIGNER_MODE=circle           # LIVE default: keyless signing via Circle DCW (no raw key signs).
                             # "local" = dev-only fallback that uses SIGNER_FALLBACK_PRIVATE_KEY below.
SIGNER_FALLBACK_PRIVATE_KEY=0xREPLACE_WITH_YOUR_OWN_64_HEX_PRIVATE_KEY   # local mode only; unused in circle

# ─────────────────────────────────────────────────────────────────────────────
# CIRCLE DCW WALLET (Day 1+: Keyless signing via Circle)
# Generate via: npm run generate-wallet
# ─────────────────────────────────────────────────────────────────────────────
AGENT_WALLET_ID=your_wallet_id_here
AGENT_WALLET_ADDRESS=0xYourCircleControlledWalletAddressHere

# ─────────────────────────────────────────────────────────────────────────────
# LLM PLANNING (Optional: Agent has deterministic mode without API)
# Get from https://console.anthropic.com
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# SERVICE PROVIDERS (Receiving payments)
# Demo addresses (generated for testing):
# ─────────────────────────────────────────────────────────────────────────────
SELLER_ADDRESS_A=0xD11d8043598001ea7DB8657f6AF165BDB962a294
SELLER_ADDRESS_B=0x3Fd8c634265cCe09590251BADEEc1052e67A4C7a
SELLER_ADDRESS_C=0xD3F15Ee24F10d9AcD5CF89d8F4743B413650Aff5

# ─────────────────────────────────────────────────────────────────────────────
# NETWORK CONFIGURATION (Local Development)
# ─────────────────────────────────────────────────────────────────────────────
SIGNER_PORT=5001
SIGNER_URL=http://localhost:5001
SELLER_PORT_A=4001
SELLER_PORT_B=4002
SELLER_PORT_C=4003
GATEWAY_FACILITATOR_URL=https://gateway-api-testnet.circle.com

# ─────────────────────────────────────────────────────────────────────────────
# SPENDGUARD POLICY LIMITS (Decimal USDC amounts)
# Enforces spending constraints at payment time
# ─────────────────────────────────────────────────────────────────────────────
POLICY_MONTHLY_BUDGET=10
POLICY_PER_SERVICE_CAP=3
POLICY_PER_TX_MAX=0.05
POLICY_APPROVAL_THRESHOLD=0.02
POLICY_DAILY_TX_MAX=200
APPROVAL_WAIT_MS=60000

# ─────────────────────────────────────────────────────────────────────────────
# AGENT AUTONOMOUS BEHAVIOR
# ─────────────────────────────────────────────────────────────────────────────
AGENT_TICK_MS=20000
AGENT_CALLS_PER_TICK=3

# ─────────────────────────────────────────────────────────────────────────────
# ARC ANCHORING (Day 4+: Policy verification on-chain)
# Deploy contract and set address here
# ─────────────────────────────────────────────────────────────────────────────
ANCHOR_CONTRACT_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# DASHBOARD (Next.js client-side signer URL)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SIGNER_URL=http://localhost:5001
